{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shutdown Windows",
  "version": "0.1.2",
  "identifier": "com.amhanisa.shutdown-windows",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Shutdown Windows",
        "width": 400,
        "height": 520,
        "center": true,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
